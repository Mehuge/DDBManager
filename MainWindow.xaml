<Window x:Class="DDBManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:DDBManager.Models"
        xmlns:local="clr-namespace:DDBManager"
        Title="DDB Management Console" Height="900" Width="1250" WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/app_icon.png">

    <Window.Resources>
        <local:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ToolBar Grid.Row="0">
            <Button Content="📁 Open Store" Click="BtnSelectStore_Click" 
                    IsEnabled="{Binding IsProcessRunning, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"/>
            <Separator/>
            <TextBlock Text="{Binding StorePath}" VerticalAlignment="Center" Margin="10,0" FontStyle="Italic"/>
        </ToolBar>

        <TabControl Grid.Row="1" Margin="5">
            <TabItem Header="Restore Explorer">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TreeView Grid.Column="0" ItemsSource="{Binding BackupTree}" SelectedItemChanged="LeftTree_SelectedItemChanged">
                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type models:BackupSetNode}" ItemsSource="{Binding Instances}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📦 "/>
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                            <DataTemplate DataType="{x:Type models:BackupInstanceNode}">
                                <DockPanel LastChildFill="True">
                                    <TextBlock Text="{Binding Timestamp}" VerticalAlignment="Center">
                                        <TextBlock.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Delete" Click="MenuDeleteInstance_Click"/>
                                            </ContextMenu>
                                        </TextBlock.ContextMenu>
                                    </TextBlock>
                                </DockPanel>
                            </DataTemplate>
                        </TreeView.Resources>
                    </TreeView>

                    <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="#EEE"/>

                    <DockPanel Grid.Column="2">
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🔍 Filter Files:" VerticalAlignment="Center" Margin="5,0"/>
                            <TextBox Grid.Column="1" Text="{Binding FileFilter, UpdateSourceTrigger=PropertyChanged}" Margin="5,0"/>
                        </Grid>

                        <Button DockPanel.Dock="Bottom" Content="RESTORE SELECTED" Click="BtnRestore_Click" Height="40" Background="SteelBlue" Foreground="White"/>

                        <TreeView ItemsSource="{Binding FileTree}" TreeViewItem.Expanded="RightTree_Expanded">
                            <TreeView.Resources>
                                <HierarchicalDataTemplate DataType="{x:Type models:FileSystemNode}" ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock Text="{Binding Icon}" Margin="0,0,5,0"/>
                                        <TextBlock Text="{Binding Name}"/>
                                        <TextBlock Text="{Binding SizeDisplay}" Foreground="Gray" Margin="10,0,0,0"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.Resources>
                        </TreeView>
                    </DockPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Maintenance &amp; Backup">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="420"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ScrollViewer Grid.Column="0">
                        <StackPanel Margin="10">
                            <TextBlock Text="Maintenance" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                            <UniformGrid Columns="2">
                                <Button Content="ddb verify" Click="BtnRunCheck_Click" Margin="2" 
                                        IsEnabled="{Binding IsProcessRunning, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"/>
                                <Button Content="ddb clean" Click="BtnRunCleanup_Click" Margin="2" 
                                        IsEnabled="{Binding IsProcessRunning, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"/>
                            </UniformGrid>

                            <Expander Header="Global Excludes/Includes" Margin="0,10,0,10">
                                <StackPanel Margin="5">
                                    <TextBlock Text="Global Excludes:" FontSize="11" Foreground="Gray"/>
                                    <ListBox Height="100" ItemsSource="{Binding GlobalExcludes}" x:Name="ListGlobalExcludes"/>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="TxtGlobalExcludeInput" KeyDown="TxtGlobalExcludeInput_KeyDown" VerticalAlignment="Center"/>
                                        <Button Content="+" Grid.Column="1" Width="25" Click="BtnAddGlobalExclude_Click" Margin="2,0"/>
                                        <Button Content="-" Grid.Column="2" Width="25" Click="BtnRemoveGlobalExclude_Click"/>
                                    </Grid>
                                    <TextBlock Text="Global Includes:" FontSize="11" Foreground="Gray" Margin="0,5,0,0"/>
                                    <ListBox Height="100" ItemsSource="{Binding GlobalIncludes}" x:Name="ListGlobalIncludes"/>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="TxtGlobalIncludeInput" KeyDown="TxtGlobalIncludeInput_KeyDown" VerticalAlignment="Center"/>
                                        <Button Content="+" Grid.Column="1" Width="25" Click="BtnAddGlobalInclude_Click" Margin="2,0"/>
                                        <Button Content="-" Grid.Column="2" Width="25" Click="BtnRemoveGlobalInclude_Click"/>
                                    </Grid>
                                </StackPanel>
                            </Expander>

                            <TextBlock Text="Backup Profiles" FontWeight="Bold" FontSize="14" Margin="0,5,0,5"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}" DisplayMemberPath="SetName" VerticalAlignment="Center"/>
                                <Button Content="+" Grid.Column="1" Width="30" Margin="5,0,0,0" Click="BtnAddProfile_Click"/>
                                <Button Content="-" Grid.Column="2" Width="30" Margin="5,0,0,0" Click="BtnDeleteProfile_Click"/>
                            </Grid>

                            <StackPanel DataContext="{Binding SelectedProfile}" 
                                        IsEnabled="{Binding DataContext.IsProcessRunning, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}">
                                <TextBlock Text="Set Name (--set-name):"/>
                                <TextBox Text="{Binding SetName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                                <TextBlock Text="Source Folder (--from):"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding SourcePath, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                                    <Button Content="..." Grid.Column="1" Width="30" Margin="5,0,0,0" Click="BtnBrowseSource_Click"/>
                                </Grid>
                                <TextBlock Text="Profile Excludes:"/>
                                <ListBox Height="70" ItemsSource="{Binding Excludes}" x:Name="ListExcludes"/>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtExcludeInput" KeyDown="TxtExcludeInput_KeyDown" VerticalAlignment="Center"/>
                                    <Button Content="+" Grid.Column="1" Width="30" Margin="5,0,0,0" Click="BtnAddExclude_Click"/>
                                    <Button Content="-" Grid.Column="2" Width="30" Margin="5,0,0,0" Click="BtnRemoveExclude_Click"/>
                                </Grid>
                                <TextBlock Text="Profile Includes:"/>
                                <ListBox Height="70" ItemsSource="{Binding Includes}" x:Name="ListIncludes"/>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtIncludeInput" KeyDown="TxtIncludeInput_KeyDown" VerticalAlignment="Center"/>
                                    <Button Content="+" Grid.Column="1" Width="30" Margin="5,0,0,0" Click="BtnAddInclude_Click"/>
                                    <Button Content="-" Grid.Column="2" Width="30" Margin="5,0,0,0" Click="BtnRemoveInclude_Click"/>
                                </Grid>
                            </StackPanel>

                            <Grid Margin="0,20,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <Button Content="START BACKUP" Click="BtnRunBackup_Click" Height="45" Background="DarkGreen" Foreground="White" FontWeight="Bold" 
                                        IsEnabled="{Binding IsProcessRunning, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}"/>
                                <Button Grid.Column="1" Content="STOP" Click="BtnStop_Click" Background="DarkRed" Foreground="White" FontWeight="Bold" 
                                        IsEnabled="{Binding IsProcessRunning}"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <GroupBox Grid.Column="1" Header="Console Output">
                        <TextBox Text="{Binding ConsoleOutput}" IsReadOnly="True" Background="Black" Foreground="LightGreen" FontFamily="Consolas" 
                                 VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" TextChanged="Console_TextChanged"/>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>
        <StatusBar Grid.Row="2">
            <TextBlock Text="{Binding Status}"/>
        </StatusBar>
    </Grid>
</Window>
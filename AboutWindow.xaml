<Window x:Class="DDBManager.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About DDB Manager" Height="260" Width="450" 
        Icon="pack://application:,,,/app_icon.png"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False"
        Background="#F3F3F3">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Viewbox Grid.Column="0" VerticalAlignment="Top" Margin="0,10,0,0">
            <Image Source="/app_icon.png" 
           Width="100" Height="100"
           RenderOptions.BitmapScalingMode="HighQuality"/>
        </Viewbox>

        <Grid Grid.Column="1" Margin="20,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" VerticalAlignment="Top">
                <TextBlock Text="DDB Manager" FontSize="22" FontWeight="Bold" Foreground="#333"/>
                <TextBlock Text="{Binding DisplayVersion}" Margin="0,2,0,15" Foreground="Gray"/>

                <TextBlock Text="A solid backup management tool designed for speed and reliability." 
                           TextWrapping="Wrap" LineHeight="18" Foreground="#444"/>

                <TextBlock Text="© 2026 Mehuge" Margin="0,15,0,0" FontSize="11" Foreground="DimGray"/>
                <TextBlock Text="https://github.com/Mehuge/DDBManager" FontSize="10" Foreground="SteelBlue" Cursor="Hand"/>
            </StackPanel>

            <Button Grid.Row="1" Content="Close" Click="Close_Click" 
                    HorizontalAlignment="Right" Width="85" Height="28" 
                    IsDefault="True" />
        </Grid>
    </Grid>
</Window>